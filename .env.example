# =============================================================================
# cleanScheduler - environment variables (template)
# =============================================================================
# Copy this file to `.env.local` for local dev. Do NOT commit .env.local.
#
# Per implementation plan section 16:
#   - NEXT_PUBLIC_APP_ENV identifies which environment this process is running
#     in. The Zod validator in lib/env.ts will throw at startup if it does not
#     match the URL conventions wired up in CI / Vercel.
#   - All NEXT_PUBLIC_* vars are inlined into the browser bundle. Do NOT put
#     secrets in those.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# One of: local | dev | prod
NEXT_PUBLIC_APP_ENV=local

# Wildcard root for tenant subdomains.
#   local: lvh.me:3000           (lvh.me resolves *.lvh.me -> 127.0.0.1)
#   dev:   dev.cleanscheduler.com
#   prod:  cleanscheduler.com
NEXT_PUBLIC_APP_DOMAIN=lvh.me:3000

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
# Optional (server-only). If set, `lib/env.ts` refuses to start when NEXT_PUBLIC_APP_ENV is local|dev
# and NEXT_PUBLIC_SUPABASE_URL contains this substring (e.g. your production project ref). Use to
# avoid accidentally wiring a dev build to production Supabase.
# SUPABASE_DISALLOW_PROJECT_REF=abcdefghijklmnop

# Auth providers are configured in the Supabase dashboard (not in .env):
#   - Authentication → Providers → Email: enable "Confirm email" only if you
#     want verification; disable for faster local/dev password sign-up.
#   - Authentication → Providers → Google: add OAuth client ID/secret from
#     Google Cloud Console (authorized redirect URI = Supabase callback URL).
#   - Authentication → URL Configuration: add every callback origin you use,
#     e.g. https://admin.dev.yourdomain.com/auth/callback
#   - Authentication → MFA: enable TOTP (Time-based One-Time Password). Required
#     for tenant owner/admin before Plaid bank connection and for platform admins.
# onboarding email confirmation mode:
#   auto     = local/dev auto-confirm; prod requires confirmation
#   required = always require confirmation
#   disabled = always auto-confirm (dev convenience)
ONBOARDING_EMAIL_CONFIRM_MODE=auto

# -----------------------------------------------------------------------------
# Stripe (Phase 1: cleanScheduler subscription + Stripe Connect)
# -----------------------------------------------------------------------------

# Leave blank until Stripe is wired up; the Zod schema treats these as
# optional during scaffolding.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Stripe event destinations (Developers → Webhooks). Scope is ONE per destination in the Dashboard:
#   (1) Your account  → https://<your-apex>/api/webhooks/stripe
#   (2) Connected accounts → same URL https://<your-apex>/api/webhooks/stripe
# Each destination has its own signing secret — set both env vars below.
#
# Destination (1) — Your account — tenant pays you (Pro/Starter subscription):
#   checkout.session.completed, customer.subscription.created|updated|deleted|trial_will_end
STRIPE_WEBHOOK_SECRET=
#
# Destination (2) — Connected accounts — tenant invoice pay, customer subs, Connect onboarding:
#   account.updated, checkout.session.completed, customer.subscription.*, refund.*, charge.dispute.*, payout.*
STRIPE_CONNECT_WEBHOOK_SECRET=
# Platform subscription — Stripe recurring Price IDs per tier and interval.
# Monthly (required for subscribe checkout; legacy STRIPE_PLATFORM_PRICE_* still work as fallbacks):
STRIPE_PLATFORM_PRICE_STARTER_MONTHLY=
STRIPE_PLATFORM_PRICE_BUSINESS_MONTHLY=
STRIPE_PLATFORM_PRICE_PRO_MONTHLY=
# Yearly (optional until annual checkout is enabled):
STRIPE_PLATFORM_PRICE_STARTER_YEARLY=
STRIPE_PLATFORM_PRICE_BUSINESS_YEARLY=
STRIPE_PLATFORM_PRICE_PRO_YEARLY=
# Legacy fallbacks (deprecated — prefer *_MONTHLY / *_YEARLY above):
STRIPE_PLATFORM_PRICE_STARTER=
STRIPE_PLATFORM_PRICE_PRO=
STRIPE_PLATFORM_PRICE_BUSINESS=
# STRIPE_PLATFORM_PRICE_PRO_SUBSCRIBE=price_...
# STRIPE_PLATFORM_PRICE_BUSINESS_SUBSCRIBE=price_...
# Optional fallback: if set, used when a tier-specific price above is empty (single-price dev setups).
STRIPE_PLATFORM_PRICE_ID=
STRIPE_CONNECT_CLIENT_ID=
# Optional. If set, `billingPortal.sessions.create` on connected accounts uses this configuration id.
# STRIPE_CONNECT_BILLING_PORTAL_CONFIGURATION_ID=bpc_...
# Optional: application fee on tenant **invoice** Checkout and **customer subscription** Checkout (basis points;
# subscriptions map to Stripe application_fee_percent = BPS/100). Capped below invoice amount for one-time pay.
# STRIPE_CONNECT_APPLICATION_FEE_BPS=0

# -----------------------------------------------------------------------------
# Plaid (Phase 2: bank reconciliation)
# -----------------------------------------------------------------------------

PLAID_CLIENT_ID=
PLAID_SECRET=
# One of: sandbox | development | production
PLAID_ENV=sandbox
# Webhook URL registered in Plaid Dashboard: https://<your-apex>/api/webhooks/plaid
# Optional: passed to linkTokenCreate so new links inherit the webhook endpoint.
# PLAID_WEBHOOK_URL=https://cleanscheduler.com/api/webhooks/plaid
# Set to false only for local sandbox testing without JWT verification.
# PLAID_WEBHOOK_VERIFY=true

# -----------------------------------------------------------------------------
# sent.dm (Pro transactional SMS)
# Webhook: https://<your-apex>/api/webhooks/sent
# -----------------------------------------------------------------------------

SENT_DM_API_KEY=
SENT_WEBHOOK_SECRET=
SENT_DM_TEMPLATE_QUOTE_SENT=
SENT_DM_TEMPLATE_QUOTE_ACCEPTED=
SENT_DM_TEMPLATE_QUOTE_DECLINED=
SENT_DM_TEMPLATE_VISIT_REMINDER=
SENT_DM_TEMPLATE_INVOICE_OVERDUE=

# -----------------------------------------------------------------------------
# Resend (transactional email — quotes, portal invites, future invoice mail)
# -----------------------------------------------------------------------------

# API key from https://resend.com/api-keys — server-only; never expose to the client bundle.
RESEND_API_KEY=
# Required for non-template sends (e.g. quote notifications, tenant invoice emails). Portal invite emails use the dashboard template’s from/subject.
RESEND_FROM_EMAIL=
# Optional. Published template id or alias for customer portal invites (default: create-customer-account).
# RESEND_CUSTOMER_INVITE_TEMPLATE_ID=create-customer-account
# Webhook endpoint for campaign delivery/open/click events: https://<your-apex>/api/webhooks/resend
# Configure in Resend dashboard → Webhooks (email.delivered, email.opened, email.clicked, email.bounced).

# -----------------------------------------------------------------------------
# Sentry (observability)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SENTRY_DSN=

# -----------------------------------------------------------------------------
# Cron (Vercel Cron + manual)
# -----------------------------------------------------------------------------

# Optional. When set, GET /api/cron/materialize-recurring-visits requires header:
#   Authorization: Bearer <CRON_SECRET>
# Vercel Cron sends this automatically when the env var is configured on the project.
# CRON_SECRET=

# -----------------------------------------------------------------------------
# Marketing screenshots (optional — npm run marketing:screenshots)
# -----------------------------------------------------------------------------

# Demo tenant used by scripts/marketing-screenshots/capture.spec.ts
# MARKETING_SCREENSHOT_TENANT_SLUG=demo
# MARKETING_SCREENSHOT_EMAIL=owner@example.com
# MARKETING_SCREENSHOT_PASSWORD=
# MARKETING_SCREENSHOT_BASE_URL=http://lvh.me:3000

# -----------------------------------------------------------------------------
# Vercel — white-label customer portal (Pro)
# -----------------------------------------------------------------------------
# Create a token at https://vercel.com/account/tokens with access to the team/project.
# When set, saving a tenant custom domain registers it on this Vercel project via API;
# tenants only add DNS at their registrar — no manual Vercel dashboard steps.
# VERCEL_API_TOKEN=
# VERCEL_PROJECT_ID=prj_xxxxxxxxxxxxxxxxxxxx
# VERCEL_PROJECT_NAME=your-vercel-project-slug
# VERCEL_TEAM_ID=team_xxxxxxxxxxxxxxxxxxxx
# Optional — pin white-label domains to a non-production Vercel deployment (set on dev only):
# VERCEL_DOMAIN_GIT_BRANCH=develop
# VERCEL_DOMAIN_CUSTOM_ENVIRONMENT_ID=env_xxxxxxxxxxxxxxxxxxxx

# -----------------------------------------------------------------------------
# Supabase Management API — white-label OAuth redirect URLs
# -----------------------------------------------------------------------------
# Personal access token from https://supabase.com/dashboard/account/tokens
# with permission to update project Auth config (auth_config write).
# When set, activating a tenant white-label domain adds
# https://portal.client.com/auth/callback to Supabase Redirect URLs automatically.
# SUPABASE_ACCESS_TOKEN=
# SUPABASE_PROJECT_REF=khodybakkdpheqkoycgi
