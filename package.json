{
  "name": "cleanscheduler",
  "version": "1.0.0",
  "private": true,
  "description": "Multi-tenant scheduling, quoting, billing, and customer-service platform for residential and commercial cleaning businesses.",
  "scripts": {
    "dev": "next dev --turbopack",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "lint:styles": "stylelint \"**/*.{css,scss,module.scss}\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:migrations": "node scripts/check-migration-prefixes.mjs",
    "check:migration-drift": "node scripts/check-migration-drift.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test -c playwright.smoke.config.ts",
    "check:engines": "node scripts/check-engines.mjs",
    "marketing:screenshots": "playwright test -c playwright.config.ts",
    "db:types": "supabase gen types typescript --linked --schema public",
    "db:prod-baseline": "bash supabase/scripts/build-prod-baseline.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@radix-ui/react-visually-hidden": "^1.1.2",
    "@supabase/ssr": "^0.5.2",
    "@supabase/supabase-js": "^2.49.4",
    "@types/pdfkit": "^0.17.6",
    "jose": "^5.10.0",
    "lucide-react": "^0.468.0",
    "next": "^15.1.6",
    "pdfkit": "^0.18.0",
    "plaid": "^42.2.0",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-plaid-link": "^4.1.1",
    "resend": "^6.12.3",
    "rrule": "^2.8.1",
    "sharp": "^0.34.5",
    "stripe": "^17.7.0",
    "twilio": "^5.13.1",
    "zod": "^3.24.1",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.49.1",
    "@types/node": "^22.10.7",
    "@types/react": "^19.0.7",
    "@types/react-dom": "^19.0.3",
    "@types/zxcvbn": "^4.4.5",
    "eslint": "^9.18.0",
    "eslint-config-next": "^15.1.6",
    "modern-normalize": "^3.0.1",
    "prettier": "^3.4.2",
    "sass": "^1.83.4",
    "stylelint": "^16.13.2",
    "stylelint-config-standard-scss": "^14.0.0",
    "stylelint-order": "^6.0.4",
    "typescript": "^5.7.3",
    "vitest": "^3.2.4"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
