# =============================================================================
# cleanScheduler - environment variables (template)
# =============================================================================
# Copy this file to `.env.local` for local dev. Do NOT commit .env.local.
#
# Per implementation plan section 16:
#   - NEXT_PUBLIC_APP_ENV identifies which environment this process is running
#     in. The Zod validator in lib/env.ts will throw at startup if it does not
#     match the URL conventions wired up in CI / Vercel.
#   - All NEXT_PUBLIC_* vars are inlined into the browser bundle. Do NOT put
#     secrets in those.

# -----------------------------------------------------------------------------
# Application
# -----------------------------------------------------------------------------

# One of: local | dev | prod
NEXT_PUBLIC_APP_ENV=local

# Wildcard root for tenant subdomains.
#   local: lvh.me:3000           (lvh.me resolves *.lvh.me -> 127.0.0.1)
#   dev:   dev.cleanscheduler.com
#   prod:  cleanscheduler.com
NEXT_PUBLIC_APP_DOMAIN=lvh.me:3000

# -----------------------------------------------------------------------------
# Supabase
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Auth providers are configured in the Supabase dashboard (not in .env):
#   - Authentication → Providers → Email: enable "Confirm email" only if you
#     want verification; disable for faster local/dev password sign-up.
#   - Authentication → Providers → Google: add OAuth client ID/secret from
#     Google Cloud Console (authorized redirect URI = Supabase callback URL).
#   - Authentication → URL Configuration: add every callback origin you use,
#     e.g. https://admin.dev.yourdomain.com/auth/callback
# onboarding email confirmation mode:
#   auto     = local/dev auto-confirm; prod requires confirmation
#   required = always require confirmation
#   disabled = always auto-confirm (dev convenience)
ONBOARDING_EMAIL_CONFIRM_MODE=auto

# -----------------------------------------------------------------------------
# Stripe (Phase 1: cleanScheduler subscription + Stripe Connect)
# -----------------------------------------------------------------------------

# Leave blank until Stripe is wired up; the Zod schema treats these as
# optional during scaffolding.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
STRIPE_SECRET_KEY=
# Webhook signing secret (Stripe Dashboard → Developers → Webhooks → endpoint secret).
# Register URL: https://<your-apex>/api/webhooks/stripe
# Events (platform): checkout.session.completed, customer.subscription.created|updated|deleted
# Connect: enable "events on connected accounts" on the same endpoint; include account.updated,
# checkout.session.completed (payment + subscription modes), customer.subscription.created|updated|deleted
# so invoice pay, subscription enroll, onboarding, and platform tenant billing all sync.
STRIPE_WEBHOOK_SECRET=
# Platform subscription — one Stripe recurring Price ID per tier (Starter / Business / Pro).
STRIPE_PLATFORM_PRICE_STARTER=
STRIPE_PLATFORM_PRICE_PRO=
STRIPE_PLATFORM_PRICE_BUSINESS=
# Optional fallback: if set, used when a tier-specific price above is empty (single-price dev setups).
STRIPE_PLATFORM_PRICE_ID=
STRIPE_CONNECT_CLIENT_ID=
# Optional: application fee on tenant **invoice** Checkout and **customer subscription** Checkout (basis points;
# subscriptions map to Stripe application_fee_percent = BPS/100). Capped below invoice amount for one-time pay.
# STRIPE_CONNECT_APPLICATION_FEE_BPS=0

# -----------------------------------------------------------------------------
# Plaid (Phase 2: bank reconciliation)
# -----------------------------------------------------------------------------

PLAID_CLIENT_ID=
PLAID_SECRET=
# One of: sandbox | development | production
PLAID_ENV=sandbox

# -----------------------------------------------------------------------------
# Twilio (Phase 2: SMS)
# -----------------------------------------------------------------------------

TWILIO_ACCOUNT_SID=
TWILIO_AUTH_TOKEN=
TWILIO_FROM_NUMBER=

# -----------------------------------------------------------------------------
# Resend (transactional email — quotes, portal invites, future invoice mail)
# -----------------------------------------------------------------------------

# API key from https://resend.com/api-keys — server-only; never expose to the client bundle.
RESEND_API_KEY=
# Required for non-template sends (e.g. quote notifications). Portal invite emails use the dashboard template’s from/subject.
RESEND_FROM_EMAIL=
# Optional. Published template id or alias for customer portal invites (default: create-customer-account).
# RESEND_CUSTOMER_INVITE_TEMPLATE_ID=create-customer-account

# -----------------------------------------------------------------------------
# Sentry (observability)
# -----------------------------------------------------------------------------

NEXT_PUBLIC_SENTRY_DSN=
