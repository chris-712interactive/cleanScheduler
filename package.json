{
  "name": "cleanscheduler",
  "version": "1.2.0",
  "private": true,
  "description": "Multi-tenant scheduling, quoting, billing, and customer-service platform for residential and commercial cleaning businesses.",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings 0",
    "lint:styles": "stylelint \"**/*.{css,scss,module.scss}\"",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "check:migrations": "node scripts/check-migration-prefixes.mjs",
    "check:migration-drift": "node scripts/check-migration-drift.mjs",
    "check:rls-smoke": "node scripts/check-rls-smoke.mjs",
    "test": "vitest run",
    "test:e2e": "playwright test -c playwright.smoke.config.ts",
    "check:engines": "node scripts/check-engines.mjs",
    "marketing:screenshots": "playwright test -c playwright.config.ts",
    "db:types": "supabase gen types typescript --linked --schema public",
    "db:prod-baseline": "bash supabase/scripts/build-prod-baseline.sh"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-dialog": "^1.1.17",
    "@radix-ui/react-dropdown-menu": "^2.1.18",
    "@radix-ui/react-popover": "^1.1.17",
    "@radix-ui/react-tabs": "^1.1.15",
    "@radix-ui/react-toast": "^1.2.17",
    "@radix-ui/react-tooltip": "^1.2.10",
    "@radix-ui/react-visually-hidden": "^1.2.9",
    "@sentdm/sentdm": "^0.32.0",
    "@supabase/ssr": "^0.12.3",
    "@supabase/supabase-js": "^2.110.7",
    "@types/pdfkit": "^0.17.6",
    "canvas-confetti": "^1.9.4",
    "d3-geo": "^3.1.1",
    "jose": "^6.2.3",
    "lucide-react": "^1.24.0",
    "next": "^16.2.10",
    "pdfkit": "^0.19.1",
    "plaid": "^43.0.0",
    "qrcode": "^1.5.4",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-plaid-link": "^4.1.1",
    "resend": "^6.17.2",
    "rrule": "^2.8.1",
    "sharp": "^0.35.3",
    "stripe": "^22.3.2",
    "topojson-client": "^3.1.0",
    "us-atlas": "^3.0.1",
    "web-vitals": "^5.3.0",
    "zod": "^4.4.3",
    "zxcvbn": "^4.4.2"
  },
  "devDependencies": {
    "@playwright/test": "^1.61.1",
    "@types/canvas-confetti": "^1.9.0",
    "@types/d3-geo": "^3.1.0",
    "@types/geojson": "^7946.0.16",
    "@types/node": "^25.9.1",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.0.3",
    "@types/topojson-client": "^3.1.5",
    "@types/topojson-specification": "^1.0.5",
    "@types/zxcvbn": "^4.4.5",
    "eslint": "^9.39.4",
    "eslint-config-next": "^16.2.10",
    "modern-normalize": "^3.0.1",
    "prettier": "^3.9.5",
    "sass": "^1.101.0",
    "stylelint": "^17.14.0",
    "stylelint-config-standard-scss": "^17.0.0",
    "stylelint-order": "^8.1.1",
    "typescript": "^6.0.3",
    "vitest": "^4.1.10"
  },
  "engines": {
    "node": ">=22.22.1"
  },
  "overrides": {
    "postcss": "^8.5.10"
  }
}
